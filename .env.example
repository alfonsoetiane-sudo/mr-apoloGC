# ── APIs de IA ──────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
APIFY_TOKEN=apify_api_...

# ── WhatsApp Business (Meta Cloud API) ───────────
WHATSAPP_TOKEN=EAAxxxxxxx          # Token de acceso de la app de Meta
WHATSAPP_PHONE_ID=1234567890       # ID del número de WhatsApp Business
WHATSAPP_TO=521XXXXXXXXXX          # Tu número personal (con código país, sin +)
WHATSAPP_VERIFY_TOKEN=mrapolo_webhook_2026  # Token que pones en Meta al configurar el webhook

# ── Instagram (Meta Graph API) ───────────────────
META_IG_TOKEN=EAAxxxxxxx           # Mismo token o uno de larga duración
META_IG_USER_ID=123456789          # ID de tu cuenta de Instagram Business

# ── Seguridad ────────────────────────────────────
ADMIN_SECRET=mrapolo2026           # Para acceder a endpoints /pipeline/run y /pipeline/estado
