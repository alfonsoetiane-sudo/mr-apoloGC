{
  "_meta": {
    "nombre": "Mr. Apolo — Pipeline Completo con WhatsApp + Feedback",
    "version": "2.0",
    "descripcion": "Importa este JSON en Make.com > Scenarios > Import Blueprint",
    "instrucciones": [
      "1. Ve a Make.com > Create a new scenario",
      "2. Click en los tres puntos (...) > Import Blueprint",
      "3. Pega este JSON",
      "4. Busca todos los campos {{EN_MAYUSCULAS}} y reemplaza con tus datos reales",
      "5. Conecta las credenciales: Apify, Anthropic (HTTP), OpenAI (HTTP), WhatsApp Business, Meta Graph API, Google Sheets",
      "6. Activa el trigger de Schedule"
    ],
    "credenciales_necesarias": [
      "Apify Token",
      "Anthropic API Key (via HTTP module)",
      "OpenAI API Key (via HTTP module)",
      "WhatsApp Business API (Meta) — numero verificado",
      "Meta Graph API — Instagram Business Account",
      "Google Sheets — para guardar feedback"
    ]
  },
  "name": "Mr. Apolo — Pipeline Diario Completo",
  "flow": [
    {
      "id": 1,
      "module": "builtin:BasicScheduleTrigger",
      "version": 1,
      "parameters": {
        "interval": "DAY",
        "time": "07:00",
        "timezone": "America/Mexico_City"
      },
      "metadata": {
        "designer": { "x": 0, "y": 0 },
        "notes": "Dispara cada mañana a las 7am CDMX. Genera 2 posts: mañana (8am) y tarde (7pm)."
      }
    },

    {
      "id": 2,
      "module": "apify:RunActor",
      "version": 1,
      "parameters": {
        "actorId": "apify~instagram-scraper",
        "input": {
          "directUrls": [
            "https://www.instagram.com/thefarmersdogofficial/",
            "https://www.instagram.com/kunay_mx/",
            "https://www.instagram.com/mutt.mx/",
            "https://www.instagram.com/bleiz_dogfood/",
            "https://www.instagram.com/petgourmet_mx/",
            "https://www.instagram.com/frankiefordogs/",
            "https://www.instagram.com/wagandlove/",
            "https://www.instagram.com/petstable/",
            "https://www.instagram.com/truf.pet/",
            "https://www.instagram.com/explore/tags/AlimentoFrescoPerros/",
            "https://www.instagram.com/explore/tags/ComidaParaPerros/"
          ],
          "resultsLimit": 8,
          "addParentData": false
        }
      },
      "metadata": {
        "designer": { "x": 300, "y": 0 },
        "notes": "Scrapeea los 11 competidores configurados. Descarga imágenes de posts tipo 'image' para usarlas como referencia visual."
      }
    },

    {
      "id": 3,
      "module": "builtin:BasicAggregator",
      "version": 1,
      "parameters": {
        "sourceModule": 2,
        "fields": ["caption", "likesCount", "commentsCount", "type", "displayUrl", "timestamp", "url"]
      },
      "metadata": {
        "designer": { "x": 600, "y": 0 },
        "notes": "Agrupa todos los posts. El campo displayUrl es la imagen del post."
      }
    },

    {
      "id": 4,
      "module": "google-sheets:GetRange",
      "version": 1,
      "parameters": {
        "spreadsheetId": "{{TU_GOOGLE_SHEET_ID}}",
        "sheetName": "Feedback",
        "range": "A:E",
        "limit": 10,
        "sort": "desc"
      },
      "metadata": {
        "designer": { "x": 600, "y": 150 },
        "notes": "Lee los últimos 10 feedbacks para que Claude aprenda de ellos"
      }
    },

    {
      "id": 5,
      "module": "http:ActionSendData",
      "version": 3,
      "parameters": {
        "url": "https://api.anthropic.com/v1/messages",
        "method": "POST",
        "headers": [
          { "name": "x-api-key", "value": "{{TU_ANTHROPIC_API_KEY}}" },
          { "name": "anthropic-version", "value": "2023-06-01" },
          { "name": "content-type", "value": "application/json" }
        ],
        "body": {
          "model": "claude-sonnet-4-6",
          "max_tokens": 3000,
          "system": "Eres el agente de contenido de Mr. Apolo. Marca de COMPLEMENTO fresco de grado humano para perros en CDMX. SE MEZCLA con las croquetas, NO las reemplaza. Dos recetas: Olímpico y Titán. Voz: directa, cálida, sin rodeos, español mexicano. PROHIBIDO: guiones (-), más de 5 hashtags, sonar como IA. Genera 2 posts en JSON: {\"post_manana\": {\"tema\": \"...\", \"caption\": \"...\", \"hashtags\": [...max 5], \"prompt_imagen\": \"...prompt en inglés para OpenAI gpt-image-1, describiendo infografía con fondo #1C1C1C, acentos dorados #C9A84C, texto en español...\", \"horario\": \"8:00am\"}, \"post_tarde\": {\"tema\": \"...\", \"caption\": \"...\", \"hashtags\": [...max 5], \"prompt_imagen\": \"...\", \"horario\": \"7:00pm\"}}",
          "messages": [
            {
              "role": "user",
              "content": "Posts de competidores de hoy (top por engagement):\n{{3.result}}\n\nFeedback de posts anteriores (aprende de esto):\n{{4.values}}\n\nGenera los 2 posts del día para Mr. Apolo. Temas balanceados: uno educativo/mito y uno de ingredientes/beneficios. Captions listos para publicar."
            }
          ]
        },
        "parseResponse": true
      },
      "metadata": {
        "designer": { "x": 900, "y": 0 },
        "notes": "Claude genera 2 captions + 2 prompts de imagen. Incluye el feedback de Google Sheets."
      }
    },

    {
      "id": 6,
      "module": "builtin:BasicJsonParser",
      "version": 1,
      "parameters": {
        "input": "{{5.body.content[].text}}",
        "schema": {
          "type": "object",
          "properties": {
            "post_manana": {
              "type": "object",
              "properties": {
                "tema": { "type": "string" },
                "caption": { "type": "string" },
                "hashtags": { "type": "array" },
                "prompt_imagen": { "type": "string" },
                "horario": { "type": "string" }
              }
            },
            "post_tarde": {
              "type": "object",
              "properties": {
                "tema": { "type": "string" },
                "caption": { "type": "string" },
                "hashtags": { "type": "array" },
                "prompt_imagen": { "type": "string" },
                "horario": { "type": "string" }
              }
            }
          }
        }
      },
      "metadata": {
        "designer": { "x": 1200, "y": 0 },
        "notes": "Parsea los 2 posts generados por Claude"
      }
    },

    {
      "id": 7,
      "module": "http:ActionSendData",
      "version": 3,
      "parameters": {
        "url": "https://api.openai.com/v1/images/generations",
        "method": "POST",
        "headers": [
          { "name": "Authorization", "value": "Bearer {{TU_OPENAI_API_KEY}}" },
          { "name": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "model": "gpt-image-1",
          "prompt": "{{6.post_manana.prompt_imagen}} All text in Spanish only.",
          "size": "1024x1024",
          "quality": "high",
          "n": 1
        },
        "parseResponse": true
      },
      "metadata": {
        "designer": { "x": 1200, "y": 150 },
        "notes": "OpenAI genera imagen para el POST DE MAÑANA"
      }
    },

    {
      "id": 8,
      "module": "http:ActionSendData",
      "version": 3,
      "parameters": {
        "url": "https://api.openai.com/v1/images/generations",
        "method": "POST",
        "headers": [
          { "name": "Authorization", "value": "Bearer {{TU_OPENAI_API_KEY}}" },
          { "name": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "model": "gpt-image-1",
          "prompt": "{{6.post_tarde.prompt_imagen}} All text in Spanish only.",
          "size": "1024x1024",
          "quality": "high",
          "n": 1
        },
        "parseResponse": true
      },
      "metadata": {
        "designer": { "x": 1200, "y": 300 },
        "notes": "OpenAI genera imagen para el POST DE TARDE"
      }
    },

    {
      "id": 9,
      "module": "whatsapp:SendMessage",
      "version": 1,
      "parameters": {
        "to": "{{TU_NUMERO_WHATSAPP}}",
        "type": "image",
        "image": "{{7.body.data[].b64_json}}",
        "caption": "🐾 *POST 1 — {{6.post_manana.horario}}*\n\n{{6.post_manana.caption}}\n\n{{join(6.post_manana.hashtags, ' ')}}\n\n---\nResponde:\n✅ aprobar y publicar\n❌ + motivo para rechazar\n✏️ + texto nuevo para reemplazar el caption"
      },
      "metadata": {
        "designer": { "x": 1500, "y": 0 },
        "notes": "Envía imagen + caption del post de mañana por WhatsApp"
      }
    },

    {
      "id": 10,
      "module": "whatsapp:WatchMessages",
      "version": 1,
      "parameters": {
        "from": "{{TU_NUMERO_WHATSAPP}}",
        "timeout": 7200
      },
      "metadata": {
        "designer": { "x": 1800, "y": 0 },
        "notes": "Espera tu respuesta hasta 2 horas"
      }
    },

    {
      "id": 11,
      "module": "builtin:BasicRouter",
      "version": 1,
      "routes": [
        {
          "condition": "{{startsWith(10.body, '✅')}}",
          "label": "✅ Aprobado — Publicar",
          "modules": [
            {
              "id": 12,
              "module": "meta:CreateMediaObject",
              "version": 1,
              "parameters": {
                "ig_user_id": "{{TU_IG_BUSINESS_ID}}",
                "image_url": "{{7.body.data[].url}}",
                "caption": "{{6.post_manana.caption}}\n\n{{join(6.post_manana.hashtags, ' ')}}"
              },
              "metadata": { "notes": "Sube imagen a Instagram" }
            },
            {
              "id": 13,
              "module": "meta:PublishMedia",
              "version": 1,
              "parameters": {
                "ig_user_id": "{{TU_IG_BUSINESS_ID}}",
                "creation_id": "{{12.id}}"
              },
              "metadata": { "notes": "Publica en Instagram" }
            },
            {
              "id": 14,
              "module": "google-sheets:AddRow",
              "version": 1,
              "parameters": {
                "spreadsheetId": "{{TU_GOOGLE_SHEET_ID}}",
                "sheetName": "Feedback",
                "values": {
                  "Fecha": "{{formatDate(now, 'YYYY-MM-DD')}}",
                  "Tema": "{{6.post_manana.tema}}",
                  "Caption": "{{6.post_manana.caption}}",
                  "Resultado": "APROBADO",
                  "Comentario": "{{10.body}}"
                }
              },
              "metadata": { "notes": "Guarda aprobación en Sheets para futuro aprendizaje" }
            },
            {
              "id": 15,
              "module": "whatsapp:SendMessage",
              "version": 1,
              "parameters": {
                "to": "{{TU_NUMERO_WHATSAPP}}",
                "body": "✅ Post 1 publicado en Instagram.\n\nAhora te mando el Post 2 para las {{6.post_tarde.horario}}."
              },
              "metadata": { "notes": "Confirma la publicación y avisa que viene el post 2" }
            }
          ]
        },
        {
          "condition": "{{startsWith(10.body, '❌')}}",
          "label": "❌ Rechazado — Guardar feedback",
          "modules": [
            {
              "id": 16,
              "module": "google-sheets:AddRow",
              "version": 1,
              "parameters": {
                "spreadsheetId": "{{TU_GOOGLE_SHEET_ID}}",
                "sheetName": "Feedback",
                "values": {
                  "Fecha": "{{formatDate(now, 'YYYY-MM-DD')}}",
                  "Tema": "{{6.post_manana.tema}}",
                  "Caption": "{{6.post_manana.caption}}",
                  "Resultado": "RECHAZADO",
                  "Comentario": "{{replace(10.body, '❌', '')}}",
                  "Accion": "Claude usará este feedback mañana"
                }
              },
              "metadata": { "notes": "Guarda el rechazo. Claude lo leerá mañana." }
            },
            {
              "id": 17,
              "module": "whatsapp:SendMessage",
              "version": 1,
              "parameters": {
                "to": "{{TU_NUMERO_WHATSAPP}}",
                "body": "❌ Entendido. Feedback guardado. Mañana Claude lo tomará en cuenta.\n\nAhora te mando el Post 2 para las {{6.post_tarde.horario}}."
              },
              "metadata": { "notes": "Confirma rechazo y continúa con post 2" }
            }
          ]
        },
        {
          "condition": "{{startsWith(10.body, '✏️')}}",
          "label": "✏️ Caption modificado manualmente",
          "modules": [
            {
              "id": 18,
              "module": "meta:CreateMediaObject",
              "version": 1,
              "parameters": {
                "ig_user_id": "{{TU_IG_BUSINESS_ID}}",
                "image_url": "{{7.body.data[].url}}",
                "caption": "{{replace(10.body, '✏️', '')}}\n\n{{join(6.post_manana.hashtags, ' ')}}"
              },
              "metadata": { "notes": "Publica con el caption que escribiste tú" }
            },
            {
              "id": 19,
              "module": "google-sheets:AddRow",
              "version": 1,
              "parameters": {
                "spreadsheetId": "{{TU_GOOGLE_SHEET_ID}}",
                "sheetName": "Feedback",
                "values": {
                  "Fecha": "{{formatDate(now, 'YYYY-MM-DD')}}",
                  "Tema": "{{6.post_manana.tema}}",
                  "Caption": "{{6.post_manana.caption}}",
                  "Resultado": "MODIFICADO",
                  "Comentario": "{{10.body}}",
                  "Accion": "El usuario prefirió escribir su propio caption"
                }
              }
            }
          ]
        }
      ],
      "metadata": {
        "designer": { "x": 2100, "y": 0 },
        "notes": "Router Post 1: ✅ publica | ❌ guarda feedback | ✏️ publica con caption tuyo"
      }
    },

    {
      "id": 20,
      "module": "whatsapp:SendMessage",
      "version": 1,
      "parameters": {
        "to": "{{TU_NUMERO_WHATSAPP}}",
        "type": "image",
        "image": "{{8.body.data[].b64_json}}",
        "caption": "🐾 *POST 2 — {{6.post_tarde.horario}}*\n\n{{6.post_tarde.caption}}\n\n{{join(6.post_tarde.hashtags, ' ')}}\n\n---\nResponde:\n✅ aprobar y programar\n❌ + motivo para rechazar\n✏️ + texto nuevo para reemplazar el caption"
      },
      "metadata": {
        "designer": { "x": 2400, "y": 0 },
        "notes": "Envía el POST 2 (tarde) para aprobación"
      }
    },

    {
      "id": 21,
      "module": "whatsapp:WatchMessages",
      "version": 1,
      "parameters": {
        "from": "{{TU_NUMERO_WHATSAPP}}",
        "timeout": 7200
      },
      "metadata": {
        "designer": { "x": 2700, "y": 0 },
        "notes": "Espera respuesta para el Post 2"
      }
    },

    {
      "id": 22,
      "module": "builtin:BasicRouter",
      "version": 1,
      "routes": [
        {
          "condition": "{{startsWith(21.body, '✅')}}",
          "label": "✅ Post 2 Aprobado",
          "modules": [
            {
              "id": 23,
              "module": "meta:CreateMediaObject",
              "version": 1,
              "parameters": {
                "ig_user_id": "{{TU_IG_BUSINESS_ID}}",
                "image_url": "{{8.body.data[].url}}",
                "caption": "{{6.post_tarde.caption}}\n\n{{join(6.post_tarde.hashtags, ' ')}}",
                "scheduled_publish_time": "{{formatDate(addHours(now, 12), 'X')}}",
                "note": "Programar para las 7pm CDMX"
              }
            },
            {
              "id": 24,
              "module": "google-sheets:AddRow",
              "version": 1,
              "parameters": {
                "spreadsheetId": "{{TU_GOOGLE_SHEET_ID}}",
                "sheetName": "Feedback",
                "values": {
                  "Fecha": "{{formatDate(now, 'YYYY-MM-DD')}}",
                  "Tema": "{{6.post_tarde.tema}}",
                  "Caption": "{{6.post_tarde.caption}}",
                  "Resultado": "APROBADO",
                  "Comentario": "{{21.body}}"
                }
              }
            },
            {
              "id": 25,
              "module": "whatsapp:SendMessage",
              "version": 1,
              "parameters": {
                "to": "{{TU_NUMERO_WHATSAPP}}",
                "body": "✅ Post 2 programado para las 7:00pm.\n\n¡Listo el día! 🐾 Mañana a las 7am te mando los 2 posts del día siguiente."
              }
            }
          ]
        },
        {
          "condition": "{{startsWith(21.body, '❌')}}",
          "label": "❌ Post 2 Rechazado",
          "modules": [
            {
              "id": 26,
              "module": "google-sheets:AddRow",
              "version": 1,
              "parameters": {
                "spreadsheetId": "{{TU_GOOGLE_SHEET_ID}}",
                "sheetName": "Feedback",
                "values": {
                  "Fecha": "{{formatDate(now, 'YYYY-MM-DD')}}",
                  "Tema": "{{6.post_tarde.tema}}",
                  "Caption": "{{6.post_tarde.caption}}",
                  "Resultado": "RECHAZADO",
                  "Comentario": "{{replace(21.body, '❌', '')}}",
                  "Accion": "Claude usará este feedback mañana"
                }
              }
            },
            {
              "id": 27,
              "module": "whatsapp:SendMessage",
              "version": 1,
              "parameters": {
                "to": "{{TU_NUMERO_WHATSAPP}}",
                "body": "❌ Feedback guardado. Claude aprenderá para mañana. 👍"
              }
            }
          ]
        },
        {
          "condition": "{{startsWith(21.body, '✏️')}}",
          "label": "✏️ Post 2 Caption modificado",
          "modules": [
            {
              "id": 28,
              "module": "meta:CreateMediaObject",
              "version": 1,
              "parameters": {
                "ig_user_id": "{{TU_IG_BUSINESS_ID}}",
                "image_url": "{{8.body.data[].url}}",
                "caption": "{{replace(21.body, '✏️', '')}}\n\n{{join(6.post_tarde.hashtags, ' ')}}"
              }
            }
          ]
        }
      ],
      "metadata": {
        "designer": { "x": 3000, "y": 0 },
        "notes": "Router Post 2: ✅ programa a las 7pm | ❌ guarda feedback | ✏️ publica con caption tuyo"
      }
    }
  ],
  "metadata": {
    "instant": false,
    "version": 2,
    "scenario": {
      "roundtrips": 1,
      "maxErrors": 3,
      "autoCommit": true,
      "autoCommitTriggerLast": true,
      "sequential": true,
      "confidential": false,
      "dataloss": false,
      "dlq": false,
      "freshVariables": false
    }
  }
}
